{
  "name": "portfolio-web-components",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-optimized": "npm run optimize-images && vite build",
    "preview": "vite preview",
    "optimize-images": "node scripts/convert-to-webp.js",
    "dev-optimized": "npm run optimize-images && npm run dev",
    "analyze-bundle": "npx vite-bundle-analyzer dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "sharp": "^0.34.3",
    "three": "^0.157.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "vite": "^4.5.0"
  }
}
